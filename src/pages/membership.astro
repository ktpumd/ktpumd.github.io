---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHeader from "../components/PageHeader.astro";
import MemberCard from "../components/MemberCard.astro";
import members from "../data/members.json";

const alumniClasses = Object.keys(
  members.alumni,
) as (keyof typeof members.alumni)[];

const pledgeClassOrder = [
  "Pi", "Omicron", "Xi", "Nu", "Mu", "Lambda", "Kappa", "Iota", "Theta", 
  "Eta", "Zeta", "Epsilon", "Delta", "Gamma", "Beta", "Alpha", "Founders"
];

const brothersByClass: Record<string, typeof members.brothers> = {};
members.brothers.forEach((brother) => {
  if (!brothersByClass[brother.pledgeClass]) {
    brothersByClass[brother.pledgeClass] = [];
  }
  brothersByClass[brother.pledgeClass].push(brother);
});

const sortedClasses = Object.keys(brothersByClass).sort((a, b) => {
  const indexA = pledgeClassOrder.indexOf(a);
  const indexB = pledgeClassOrder.indexOf(b);
  return (indexA === -1 ? 999 : indexA) - (indexB === -1 ? 999 : indexB);
});

sortedClasses.forEach((className) => {
  brothersByClass[className].sort((a, b) => 
    a.firstName.localeCompare(b.firstName)
  );
});

const sortedBrothers = sortedClasses.flatMap(className => brothersByClass[className]);
---

<Layout title="Kappa Theta Pi UMD">
  <Navbar currentPage="/membership" />

  <PageHeader
    title="Meet Our Members"
    backgroundImage="/img/background.jpg"
    size="small"
  />

  <main>
    <!-- Executive Board -->
    <section class="section">
      <div class="container">
        <h2 class="section-title text-center">Executive Board</h2>
        <div class="member-grid member-grid--exec">
          {
            members.execBoard.map((member) => (
              <MemberCard
                firstName={member.firstName}
                lastName={member.lastName}
                role={member.role}
                pledgeClass={member.pledgeClass}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Chairs -->
    <section class="section section--alt">
      <div class="container">
        <h2 class="section-title text-center">Chairs</h2>
        <div class="member-grid member-grid--chairs">
          {
            members.chairs.map((member) => (
              <MemberCard
                firstName={member.firstName}
                lastName={member.lastName}
                role={member.role}
                pledgeClass={member.pledgeClass}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Brothers -->
    <section class="section">
      <div class="container">
        <h2 class="section-title text-center">Brothers</h2>
        <div class="member-grid member-grid--brothers">
          {
            sortedBrothers.map((member) => (
              <MemberCard
                firstName={member.firstName}
                lastName={member.lastName}
                pledgeClass={member.pledgeClass}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Alumni -->
    <section class="section section--alt">
      <div class="container">
        <h2 class="section-title text-center">Alumni</h2>

        <div class="alumni-grid">
          {
            alumniClasses.map((className) => (
              <div class="alumni-class card">
                <h3 class="class-title">{className}</h3>
                <div class="alumni-list">
                  {members.alumni[className].map((member) => (
                    <span class="alumni-name">
                      {member.firstName} {member.lastName}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .section-title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--spacing-10);
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--spacing-4);
    justify-items: center;
  }

  .member-grid--brothers {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  .member-grid--brothers > :global(*) {
    width: calc(20% - var(--spacing-4));
    min-width: 180px;
  }

  .member-grid--exec {
    grid-template-columns: repeat(3, 1fr);
    max-width: 900px;
    margin: 0 auto;
  }

  .member-grid--chairs {
    grid-template-columns: repeat(5, 1fr);
  }

  @media (max-width: 1200px) {
    .member-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .member-grid--chairs {
      grid-template-columns: repeat(4, 1fr);
    }
    .member-grid--brothers > :global(*) {
      width: calc(25% - var(--spacing-4));
    }
  }

  @media (max-width: 992px) {
    .member-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .member-grid--exec,
    .member-grid--chairs {
      grid-template-columns: repeat(3, 1fr);
    }
    .member-grid--brothers > :global(*) {
      width: calc(33.333% - var(--spacing-4));
    }
  }

  @media (max-width: 768px) {
    .member-grid,
    .member-grid--exec,
    .member-grid--chairs {
      grid-template-columns: repeat(2, 1fr);
    }
    .member-grid--brothers > :global(*) {
      width: calc(50% - var(--spacing-4));
    }
  }

  /* Alumni Styles */
  .alumni-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
  }

  .alumni-class {
    padding: var(--spacing-6);
  }

  .class-title {
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--spacing-4);
    text-align: center;
  }

  .alumni-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-2);
  }

  .alumni-name {
    font-size: var(--font-size-xs);
    color: var(--color-gray-400);
    padding: var(--spacing-1) var(--spacing-2);
    background: var(--color-bg-elevated);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 992px) {
    .alumni-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .alumni-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
